{
    "board": {
        "name": "Heltec WiFi LoRa 32 V3",
        "arch": "esp32s3",
        "board_id": "heltec-v3",
        "version": "1.0"
    },
    "buses": {
        "spi": [
            {
                "host": 2,
                "mosi": 10,
                "miso": 11,
                "sclk": 9,
                "max_transfer_bytes": 4096
            }
        ],
        "i2c": [
            {
                "port": 0,
                "sda": 17,
                "scl": 18,
                "freq_hz": 400000
            }
        ]
    },
    "drivers": [
        {
            "id": "com.thistle.drv.oled-ssd1306",
            "hal": "display",
            "entry": "oled-ssd1306.drv.elf",
            "config": {
                "i2c_bus": 0,
                "i2c_addr": "0x3C",
                "pin_rst": 21,
                "pin_vext": 36
            }
        },
        {
            "id": "com.thistle.drv.radio-sx1262",
            "hal": "radio",
            "entry": "radio-sx1262.drv.elf",
            "config": {
                "spi_bus": 0,
                "cs": 8,
                "dio1": 14,
                "rst": 12,
                "busy": 13,
                "tcxo": true
            }
        },
        {
            "id": "com.thistle.drv.power-heltec-v3",
            "hal": "power",
            "entry": "power-tp4065b.drv.elf",
            "config": {
                "adc_pin": 1,
                "charge_pin": -1,
                "adc_ctrl_pin": 37
            }
        }
    ]
}
